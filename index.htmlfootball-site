<!DOCTYPE html>
<html lang="ar">
<head>
<meta charset="UTF-8">
<title>Xb ALTEABANIA FOOTBALL</title>

<style>
body {
  font-family: Arial;
  background: #111;
  color: white;
  text-align: center;
}

h1 {
  color: red;
}

input, select {
  margin: 5px;
  padding: 10px;
  width: 200px;
}

button {
  padding: 10px;
  background: red;
  color: white;
  border: none;
  cursor: pointer;
}

.player {
  background: #222;
  margin: 10px;
  padding: 10px;
  border-radius: 10px;
}
img {
  width: 100px;
  height: 100px;
  border-radius: 50%;
}
</style>

</head>
<body>

<h1>Xb ALTEABANIA FOOTBALL</h1>

<h3>تسجيل لاعب</h3>

<input id="name" placeholder="اسمك">
<input id="age" placeholder="سنك" type="number">
<input id="position" placeholder="مركزك">
<input id="number" placeholder="رقمك">
<input id="email" placeholder="Gmail">
<input type="file" id="image">

<br>
<button onclick="addPlayer()">تسجيل</button>

<h2>اللاعبين</h2>
<div id="players"></div>

<script>
let players = JSON.parse(localStorage.getItem("players")) || [];

function generateCode() {
  return "XB-" + Math.floor(Math.random() * 100000);
}

function addPlayer() {
  let name = document.getElementById("name").value;
  let age = document.getElementById("age").value;
  let position = document.getElementById("position").value;
  let number = document.getElementById("number").value;
  let email = document.getElementById("email").value;
  let imageInput = document.getElementById("image").files[0];

  if (!name || !age || !position) {
    alert("املا البيانات!");
    return;
  }

  let reader = new FileReader();
  reader.onload = function () {
    let player = {
      name,
      age,
      position,
      number,
      email,
      code: generateCode(),
      image: reader.result
    };

    players.push(player);
    localStorage.setItem("players", JSON.stringify(players));
    displayPlayers();
  };

  if (imageInput) {
    reader.readAsDataURL(imageInput);
  } else {
    reader.onload();
  }
}

function displayPlayers() {
  let container = document.getElementById("players");
  container.innerHTML = "";

  players.forEach(p => {
    container.innerHTML += `
      <div class="player">
        <img src="${p.image || ''}">
        <h3>${p.name}</h3>
        <p>السن: ${p.age}</p>
        <p>المركز: ${p.position}</p>
        <p>الرقم: ${p.number}</p>
        <p>Gmail: ${p.email}</p>
        <p>الكود: ${p.code}</p>
      </div>
    `;
  });
}

displayPlayers();
</script>

</body>
</html>
